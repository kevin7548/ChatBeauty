# ===========================================
# ChatBeauty Backend Environment Variables
# ===========================================

# Gemini API (required)
GEMINI_API_KEY=your_gemini_api_key_here

# CORS (comma-separated origins, no trailing slash)
# For local dev: http://localhost:5173
# For production: https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:5173

# Debug mode (set to false in production)
DEBUG=false

# PostgreSQL (required)
DATABASE_URL=postgresql://chatbeauty:chatbeauty@localhost:5432/chatbeauty
DB_PASSWORD=chatbeauty

# Optional: Override default model path (useful for Docker)
# BGE_MODEL_PATH=/app/ml/model/retrieval/bge-m3-finetuned-20260202-120852
# RERANK_MODEL_PATH=/app/ml/model/reranking/lgbm_reranker_current_features_v1.pkl
